PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/arttube
SESSION_SECRET=replace_me_with_a_long_random_string
JWT_SECRET=super_long_random_secret_change_me

# Expo dev app origin (optional in dev; CORS is permissive)
CLIENT_ORIGIN=exp://192.168.0.3:8081

# ---------- Cloudinary (thumbnails + videos) ----------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Folder in Cloudinary where uploads are stored
CLOUDINARY_FOLDER=arttube
